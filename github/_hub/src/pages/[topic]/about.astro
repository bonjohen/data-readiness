---
import BaseLayout from '../../components/BaseLayout.astro';
import DisclaimerBanner from '../../components/DisclaimerBanner.astro';
import { getCollection } from 'astro:content';
import { discoverTopics } from '../../data/discover-topics';

export function getStaticPaths() {
  const topics = discoverTopics();
  return topics.map((t) => ({ params: { topic: t.id }, props: { topic: t } }));
}

const { topic } = Astro.props;
const pages = await getCollection('pages');
const entry = pages.find((p) => p.id === `${topic.id}/about.mdx`);
if (!entry) throw new Error(`No about page found for topic ${topic.id}`);
const { Content } = await entry.render();
---

<BaseLayout title={entry.data.title} description={entry.data.description} topic={topic}>
  <section class="content">
    <Content />
    {entry.data.disclaimers && <DisclaimerBanner statements={entry.data.disclaimers} />}
  </section>
</BaseLayout>

<style>
  .two-col {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-top: 1rem;
  }

  .offer-box {
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.5rem;
  }

  .offer-box.yes {
    border-color: var(--color-accent);
  }

  .offer-box.no {
    border-color: #f59e0b;
  }

  .offer-box h3 {
    margin-bottom: 0.75rem;
  }

  .offer-box.yes h3 {
    color: var(--color-accent);
  }

  .offer-box.no h3 {
    color: #f59e0b;
  }

  .offer-box ul {
    margin-bottom: 0;
  }

  .offer-box li {
    font-size: 0.9rem;
  }

  .staffing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-top: 1rem;
  }

  .staff-item {
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1rem;
  }

  .staff-item h4 {
    color: var(--color-accent);
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }

  .staff-item p {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 0;
  }

  .table-wrapper {
    overflow-x: auto;
  }

  .cta-section {
    text-align: center;
    padding: 2rem;
    background: var(--color-bg-alt);
    border-radius: var(--radius);
  }

  .cta-section p {
    max-width: 36rem;
    margin: 0 auto 1.5rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .two-col {
      grid-template-columns: 1fr;
    }

    .staffing-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 480px) {
    .staffing-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
