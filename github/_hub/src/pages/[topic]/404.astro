---
import BaseLayout from '../../components/BaseLayout.astro';
import { discoverTopics } from '../../data/discover-topics';

export function getStaticPaths() {
  const topics = discoverTopics();
  return topics.map((t) => ({ params: { topic: t.id }, props: { topic: t } }));
}

const { topic } = Astro.props;
---

<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist." topic={topic}>
  <section class="content error-page">
    <h1>404 — Page Not Found</h1>
    <p>The page you're looking for doesn't exist or has been moved.</p>
    <a href={`/${topic.id}/`} class="cta-button">Back to {topic.name}</a>
  </section>
</BaseLayout>

<style>
  .error-page {
    text-align: center;
    padding: 4rem 1rem;
  }

  .error-page h1 {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .error-page p {
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }
</style>
