---
import BaseLayout from '../../components/BaseLayout.astro';
import TimelineDiagram from '../../components/TimelineDiagram.astro';
import { getCollection } from 'astro:content';
import { discoverTopics } from '../../data/discover-topics';

export function getStaticPaths() {
  const topics = discoverTopics();
  return topics.map((t) => ({ params: { topic: t.id }, props: { topic: t } }));
}

const { topic } = Astro.props;
const pages = await getCollection('pages');
const entry = pages.find((p) => p.id === `${topic.id}/readiness-process.mdx`);
if (!entry) throw new Error(`No readiness-process page found for topic ${topic.id}`);
const { Content } = await entry.render();
---

<BaseLayout title={entry.data.title} description={entry.data.description} topic={topic}>
  <section class="content">
    <h1>Readiness Process</h1>

    <div class="section">
      <h2>Sprint Timeline</h2>
      <p>The engagement follows structured phases, each building on the outputs of the previous one.</p>
      <TimelineDiagram />
    </div>

    <Content />
  </section>
</BaseLayout>

<style>
  .phase-detail {
    margin-bottom: 2rem;
    padding: 1.5rem;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }

  .phase-detail h3 {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .phase-duration {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-accent);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 0.125rem 0.5rem;
  }

  .phase-detail ul {
    margin-bottom: 0;
  }

  .deliverables-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .deliverable-item {
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 0.75rem 1rem;
    font-size: 0.9rem;
    color: var(--color-heading);
  }

  .deliverable-item::before {
    content: '\2713';
    color: var(--color-accent);
    margin-right: 0.5rem;
    font-weight: 700;
  }

  .cta-section {
    text-align: center;
    padding: 2rem;
    background: var(--color-bg-alt);
    border-radius: var(--radius);
  }

  .cta-section p {
    max-width: 36rem;
    margin: 0 auto 1.5rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .deliverables-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
