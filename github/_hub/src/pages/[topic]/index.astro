---
import BaseLayout from '../../components/BaseLayout.astro';
import HeroSection from '../../components/HeroSection.astro';
import { getCollection } from 'astro:content';
import { discoverTopics } from '../../data/discover-topics';

export function getStaticPaths() {
  const topics = discoverTopics();
  return topics.map((t) => ({ params: { topic: t.id }, props: { topic: t } }));
}

const { topic } = Astro.props;
const pages = await getCollection('pages');
const entry = pages.find((p) => p.id === `${topic.id}/index.mdx`);
if (!entry) throw new Error(`No index page found for topic ${topic.id}`);
const { Content } = await entry.render();
---

<BaseLayout title={entry.data.title} description={entry.data.description} topic={topic}>
  <HeroSection
    headline={entry.data.heroHeadline || topic.name}
    subheadline={entry.data.heroSubheadline || topic.shortDescription}
    ctaText="Get Started"
    ctaHref={`/${topic.id}/about`}
  />
  <Content />
</BaseLayout>

<style>
  .value-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .value-item {
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.5rem;
  }

  .value-item h3 {
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  .value-item p {
    margin-bottom: 0;
    color: var(--color-text-muted);
  }

  .service-overview-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .service-overview-card {
    text-align: center;
    text-decoration: none;
    display: block;
  }

  .service-overview-card h3 {
    color: var(--color-heading);
    margin-bottom: 0.5rem;
  }

  .service-overview-card p {
    color: var(--color-text-muted);
    margin-bottom: 0;
    font-size: 0.9rem;
  }

  .cta-section {
    text-align: center;
    padding: 3rem var(--spacing-page);
    background: var(--color-bg-alt);
    border-radius: var(--radius);
  }

  .cta-section p {
    max-width: 36rem;
    margin: 0 auto 1.5rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .value-grid {
      grid-template-columns: 1fr;
    }

    .service-overview-grid {
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }
  }

  @media (max-width: 480px) {
    .service-overview-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
