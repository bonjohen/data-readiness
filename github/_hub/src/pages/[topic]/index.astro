---
import BaseLayout from '../../components/BaseLayout.astro';
import HeroSection from '../../components/HeroSection.astro';
import RelatedRegulations from '../../components/RelatedRegulations.astro';
import { getCollection } from 'astro:content';
import { discoverTopics } from '../../data/discover-topics';

export function getStaticPaths() {
  const topics = discoverTopics();
  return topics.map((t) => ({ params: { topic: t.id }, props: { topic: t } }));
}

const { topic } = Astro.props;
const pages = await getCollection('pages');
const entry = pages.find((p) => p.id === `${topic.id}/index.mdx`);
if (!entry) throw new Error(`No index page found for topic ${topic.id}`);
const { Content } = await entry.render();

const services = entry.data.services ?? [];
const servicesIntro = entry.data.servicesIntro ?? 'Four service packages designed to meet you where you are in your compliance journey.';
const ctaHeadline = entry.data.ctaHeadline ?? 'Ready to Get Started?';
const ctaBody = entry.data.ctaBody ?? `Whether you're pursuing compliance for the first time or need help maintaining your program, we can help you build a readiness plan that fits your team and timeline.`;
---

<BaseLayout title={entry.data.title} description={entry.data.description} topic={topic}>
  <HeroSection
    headline={entry.data.heroHeadline || topic.name}
    subheadline={entry.data.heroSubheadline || topic.shortDescription}
    ctaText="Get Started"
    ctaHref={`/${topic.id}/about`}
  />
  <Content />

  <RelatedRegulations topicId={topic.id} />

  {services.length > 0 && (
    <section class="content section">
      <h2>How We Help</h2>
      <p>{servicesIntro}</p>
      <div class="service-overview-grid">
        {services.map((s) => (
          <a href={`/${topic.id}/services`} class="card service-overview-card">
            <h3>{s.name}</h3>
            <p>{s.tagline}</p>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="content section cta-section">
    <h2>{ctaHeadline}</h2>
    <p>{ctaBody}</p>
    <a href={`/${topic.id}/about`} class="cta-button">Let's Talk</a>
  </section>
</BaseLayout>
