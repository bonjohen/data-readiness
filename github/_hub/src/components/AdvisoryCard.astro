---
interface Props {
  module_name: string;
  why_credible: string;
  additions: string[];
}

const { module_name, why_credible, additions } = Astro.props;
---

<article class="card advisory-card">
  <h3>{module_name}</h3>
  <p class="credibility">{why_credible}</p>
  <h4>What This Module Adds</h4>
  <ul class="additions-list">
    {additions.map((item) => (
      <li>{item}</li>
    ))}
  </ul>
</article>

<style>
  .advisory-card h3 {
    margin-bottom: 0.5rem;
  }

  .credibility {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    font-style: italic;
    margin-bottom: 1rem;
    padding-left: 0.75rem;
    border-left: 2px solid var(--color-accent);
  }

  .advisory-card h4 {
    font-size: 0.9rem;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }

  .additions-list {
    padding-left: 1.25rem;
    margin-bottom: 0;
  }

  .additions-list li {
    font-size: 0.9rem;
    margin-bottom: 0.25rem;
  }
</style>
