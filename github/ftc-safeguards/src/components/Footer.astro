---
import { SITE } from '../config';
---

<footer role="contentinfo" class="site-footer">
  <div class="footer-inner">
    <p class="disclaimer">We provide SOC 2 readiness, remediation, evidence preparation, and audit support. We do not issue SOC 2 reports or provide attestations.</p>
    <p class="copyright">&copy; {new Date().getFullYear()} {SITE.author}</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    padding: 2rem var(--spacing-page);
    margin-top: var(--spacing-section);
    text-align: center;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    background: var(--color-bg-alt);
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .disclaimer {
    margin-bottom: 0.5rem;
    font-style: italic;
  }

  .copyright {
    margin: 0;
  }

  .site-footer a {
    color: var(--color-accent);
  }

  .site-footer a:hover {
    color: var(--color-link-hover);
  }
</style>
