---
import BaseLayout from '../components/BaseLayout.astro';
import DisclaimerBanner from '../components/DisclaimerBanner.astro';

const disclaimers = [
  "We provide governance readiness and risk management guidance. We do not provide legal, audit, or regulatory representation.",
  "SEC cybersecurity disclosure compliance ultimately depends on the specific facts of your operations and applicable securities law.",
  "Management remains responsible for determining materiality, making disclosure decisions, and filing with the SEC.",
  "We coordinate with securities counsel as needed, but we do not act as attorneys and do not provide legal opinions.",
  "Where securities litigation, enforcement, or complex legal questions arise, qualified securities counsel is required.",
];
---

<BaseLayout title="About" description="SEC cybersecurity disclosure readiness for public companies. Learn about our approach, team, and how to get started.">
  <section class="content">
    <h1>About</h1>

    <div class="section">
      <h2>What We Do</h2>
      <p>We provide SEC cybersecurity disclosure readiness for public companies subject to SEC reporting requirements. Our service helps CISOs, general counsel, corporate secretaries, and board members navigate the disclosure rules with clear frameworks, practical procedures, and disclosure-ready documentation.</p>

      <p>We work with public companies of all sizes that file with the SEC &mdash; the companies where disclosure readiness is the difference between meeting regulatory requirements and facing enforcement risk. See <a href="/services">our service packages</a> for details on pricing and deliverables.</p>
    </div>

    <div class="section">
      <h2>What We Can Safely Offer</h2>
      <div class="two-col">
        <div class="offer-box yes">
          <h3>We Do</h3>
          <ul>
            <li>Materiality determination framework design</li>
            <li>8-K incident disclosure procedures</li>
            <li>10-K cybersecurity disclosure drafting</li>
            <li>Board oversight documentation</li>
            <li>Management role and expertise mapping</li>
            <li>Third-party risk disclosure support</li>
            <li>Incident-to-disclosure playbook development</li>
            <li>Board briefing frameworks</li>
          </ul>
        </div>
        <div class="offer-box no">
          <h3>We Do Not</h3>
          <ul>
            <li>Provide legal or securities advice</li>
            <li>Act as securities counsel</li>
            <li>Guarantee regulatory outcomes</li>
            <li>Represent companies before the SEC</li>
            <li>Prepare financial filings</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="section">
      <h2>Staffing and Skillset</h2>
      <p>Our team covers the six core competencies needed to deliver SEC cybersecurity disclosure readiness effectively:</p>

      <div class="staffing-grid">
        <div class="staff-item">
          <h4>Governance Lead</h4>
          <p>SEC disclosure fluency, board governance, and program design for public company cyber risk.</p>
        </div>
        <div class="staff-item">
          <h4>Cybersecurity Specialist</h4>
          <p>Incident response, risk management, and technical controls assessment for disclosure readiness.</p>
        </div>
        <div class="staff-item">
          <h4>Program Manager</h4>
          <p>Disclosure coordination, board reporting, and status tracking across workstreams.</p>
        </div>
        <div class="staff-item">
          <h4>Policy Writer</h4>
          <p>Disclosure procedures, board materials, and governance documentation in SEC-ready language.</p>
        </div>
        <div class="staff-item">
          <h4>Risk Assessment Specialist</h4>
          <p>Materiality determination, risk quantification, and impact analysis for disclosure decisions.</p>
        </div>
        <div class="staff-item">
          <h4>Legal Coordination</h4>
          <p>Securities law interface, disclosure review support, and counsel coordination.</p>
        </div>
      </div>
    </div>

    <div class="section">
      <h2>Our Approach</h2>
      <div class="two-col">
        <div>
          <h3>First Version</h3>
          <ul>
            <li>Readiness Sprint with materiality framework</li>
            <li>8-K procedures and 10-K disclosure drafts</li>
            <li>Board governance documentation</li>
            <li>Manual + tool-agnostic by design</li>
            <li>Executive summary + disclosure remediation plan</li>
          </ul>
        </div>
        <div>
          <h3>Later Maturity</h3>
          <ul>
            <li>Automated incident-to-disclosure workflows</li>
            <li>Board reporting dashboards</li>
            <li>Continuous materiality monitoring</li>
            <li>Cross-framework governance mappings</li>
            <li>Peer company disclosure benchmarking</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="section">
      <h2>Launch Readiness Metrics</h2>
      <p>We hold ourselves to measurable targets:</p>

      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Metric</th>
              <th>Target</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Time from kickoff to disclosure readiness report</td>
              <td>15&ndash;20 business days</td>
            </tr>
            <tr>
              <td>Materiality framework completeness</td>
              <td>Defined process with criteria, roles, and escalation paths</td>
            </tr>
            <tr>
              <td>8-K procedure coverage</td>
              <td>End-to-end incident-to-filing workflow documented</td>
            </tr>
            <tr>
              <td>10-K disclosure coverage</td>
              <td>All required Items 106(b) and 106(c) sections drafted</td>
            </tr>
            <tr>
              <td>Board governance documentation</td>
              <td>Oversight mechanisms documented in disclosure-ready form</td>
            </tr>
            <tr>
              <td>Disclosure drill turnaround</td>
              <td>Tabletop exercise completed within readiness sprint</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <div class="section cta-section">
      <h2>Get in Touch</h2>
      <p>Ready to build your SEC cybersecurity disclosure program? Reach out to discuss your filing timeline, governance structure, and goals.</p>
      <a href="mailto:john@johnboen.com" class="cta-button">Email Us</a>
    </div>

    <DisclaimerBanner statements={disclaimers} />
  </section>
</BaseLayout>

<style>
  .two-col {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-top: 1rem;
  }

  .offer-box {
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.5rem;
  }

  .offer-box.yes {
    border-color: var(--color-accent);
  }

  .offer-box.no {
    border-color: #f59e0b;
  }

  .offer-box h3 {
    margin-bottom: 0.75rem;
  }

  .offer-box.yes h3 {
    color: var(--color-accent);
  }

  .offer-box.no h3 {
    color: #f59e0b;
  }

  .offer-box ul {
    margin-bottom: 0;
  }

  .offer-box li {
    font-size: 0.9rem;
  }

  .staffing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-top: 1rem;
  }

  .staff-item {
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1rem;
  }

  .staff-item h4 {
    color: var(--color-accent);
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }

  .staff-item p {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 0;
  }

  .table-wrapper {
    overflow-x: auto;
  }

  .cta-section {
    text-align: center;
    padding: 2rem;
    background: var(--color-bg-alt);
    border-radius: var(--radius);
  }

  .cta-section p {
    max-width: 36rem;
    margin: 0 auto 1.5rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .two-col {
      grid-template-columns: 1fr;
    }

    .staffing-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 480px) {
    .staffing-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
