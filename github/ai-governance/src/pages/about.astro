---
import BaseLayout from '../components/BaseLayout.astro';
import DisclaimerBanner from '../components/DisclaimerBanner.astro';

const disclaimers = [
  "We provide governance readiness and risk management guidance. We do not provide legal, audit, or regulatory representation.",
  "AI governance compliance ultimately depends on the specific facts of your systems, use cases, and applicable regulations.",
  "Management remains responsible for AI system development, deployment, and governance decisions.",
  "We coordinate with legal counsel as needed, but we do not act as attorneys and do not provide legal opinions.",
  "Where regulatory enforcement, litigation, or complex legal questions arise, qualified legal counsel is required.",
];
---

<BaseLayout title="About" description="AI governance and regulatory readiness for technology companies. Learn about our approach, team, and how to get started.">
  <section class="content">
    <h1>About</h1>

    <div class="section">
      <h2>What We Do</h2>
      <p>We provide AI governance and regulatory readiness for technology companies developing or deploying AI systems. Our service helps AI leaders, CTOs, and risk officers build responsible AI practices with clear frameworks, practical controls, and governance documentation that satisfies regulators and enterprise buyers.</p>

      <p>We work with technology companies of all sizes that develop or deploy AI systems &mdash; the companies where AI governance is the difference between responsible innovation and regulatory exposure. See <a href="/services">our service packages</a> for details on pricing and deliverables.</p>
    </div>

    <div class="section">
      <h2>What We Can Safely Offer</h2>
      <div class="two-col">
        <div class="offer-box yes">
          <h3>We Do</h3>
          <ul>
            <li>AI system inventory and classification</li>
            <li>Risk categorization (NIST AI RMF, EU AI Act)</li>
            <li>Bias testing methodology design</li>
            <li>Transparency and explainability frameworks</li>
            <li>Human oversight mechanism design</li>
            <li>Data governance for AI</li>
            <li>Model lifecycle management</li>
            <li>Third-party AI risk assessment</li>
          </ul>
        </div>
        <div class="offer-box no">
          <h3>We Do Not</h3>
          <ul>
            <li>Provide legal advice or representation</li>
            <li>Certify AI systems</li>
            <li>Guarantee regulatory outcomes</li>
            <li>Perform bias audits as independent assessors</li>
            <li>Represent companies before regulators</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="section">
      <h2>Staffing and Skillset</h2>
      <p>Our team covers the six core competencies needed to deliver AI governance readiness effectively:</p>

      <div class="staffing-grid">
        <div class="staff-item">
          <h4>AI Governance Lead</h4>
          <p>NIST AI RMF fluency, EU AI Act expertise, and governance program design for AI organizations.</p>
        </div>
        <div class="staff-item">
          <h4>ML/AI Specialist</h4>
          <p>Model risk assessment, bias testing methodologies, and explainability methods for production AI systems.</p>
        </div>
        <div class="staff-item">
          <h4>Program Manager</h4>
          <p>Governance coordination, stakeholder management, and status reporting across workstreams.</p>
        </div>
        <div class="staff-item">
          <h4>Policy Writer</h4>
          <p>AI policies, transparency documentation, and governance procedures in clear, actionable language.</p>
        </div>
        <div class="staff-item">
          <h4>Risk Assessment Specialist</h4>
          <p>AI risk categorization, impact assessment, and mitigation strategy design for high-risk systems.</p>
        </div>
        <div class="staff-item">
          <h4>Data Governance Specialist</h4>
          <p>Training data quality, data lineage, provenance tracking, and data quality management for AI systems.</p>
        </div>
      </div>
    </div>

    <div class="section">
      <h2>Our Approach</h2>
      <div class="two-col">
        <div>
          <h3>First Version</h3>
          <ul>
            <li>Readiness Sprint with AI system inventory</li>
            <li>Risk categorization matrix and governance framework</li>
            <li>Bias testing methodology and transparency templates</li>
            <li>Manual + tool-agnostic by design</li>
            <li>Executive summary + governance remediation plan</li>
          </ul>
        </div>
        <div>
          <h3>Later Maturity</h3>
          <ul>
            <li>Automated model monitoring and drift detection</li>
            <li>Continuous bias testing pipelines</li>
            <li>AI risk dashboards</li>
            <li>Multi-framework governance mappings</li>
            <li>AI procurement and vendor governance</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="section">
      <h2>Launch Readiness Metrics</h2>
      <p>We hold ourselves to measurable targets:</p>

      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Metric</th>
              <th>Target</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Time from kickoff to governance readiness report</td>
              <td>15&ndash;20 business days</td>
            </tr>
            <tr>
              <td>AI system inventory completeness</td>
              <td>100% of production and development AI systems cataloged</td>
            </tr>
            <tr>
              <td>Risk categorization coverage</td>
              <td>Every AI system classified with risk level and rationale</td>
            </tr>
            <tr>
              <td>Bias testing coverage</td>
              <td>Methodology defined for all high-risk AI systems</td>
            </tr>
            <tr>
              <td>Transparency documentation</td>
              <td>Documentation templates available for all high-risk systems</td>
            </tr>
            <tr>
              <td>Governance framework completeness</td>
              <td>Policies, roles, and oversight structure documented</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <div class="section cta-section">
      <h2>Get in Touch</h2>
      <p>Ready to build your AI governance program? Reach out to discuss your AI systems, regulatory exposure, and goals.</p>
      <a href="mailto:john@johnboen.com" class="cta-button">Email Us</a>
    </div>

    <DisclaimerBanner statements={disclaimers} />
  </section>
</BaseLayout>

<style>
  .two-col {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-top: 1rem;
  }

  .offer-box {
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.5rem;
  }

  .offer-box.yes {
    border-color: var(--color-accent);
  }

  .offer-box.no {
    border-color: #f59e0b;
  }

  .offer-box h3 {
    margin-bottom: 0.75rem;
  }

  .offer-box.yes h3 {
    color: var(--color-accent);
  }

  .offer-box.no h3 {
    color: #f59e0b;
  }

  .offer-box ul {
    margin-bottom: 0;
  }

  .offer-box li {
    font-size: 0.9rem;
  }

  .staffing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-top: 1rem;
  }

  .staff-item {
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1rem;
  }

  .staff-item h4 {
    color: var(--color-accent);
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }

  .staff-item p {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 0;
  }

  .table-wrapper {
    overflow-x: auto;
  }

  .cta-section {
    text-align: center;
    padding: 2rem;
    background: var(--color-bg-alt);
    border-radius: var(--radius);
  }

  .cta-section p {
    max-width: 36rem;
    margin: 0 auto 1.5rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .two-col {
      grid-template-columns: 1fr;
    }

    .staffing-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 480px) {
    .staffing-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
