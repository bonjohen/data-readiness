---
const phases = [
  { name: 'Intake', duration: '2\u20136 days', activities: ['NDA & stakeholder map', 'Document request', 'Scoping interviews', 'System boundary draft'] },
  { name: 'Assessment', duration: '9 days', activities: ['TSC selection', 'Type 1/Type 2 recommendation', 'Control walkthroughs', 'Evidence sampling'] },
  { name: 'Outputs', duration: '9 days', activities: ['Controls matrix & gap register', 'Policy/document backlog', 'Evidence calendar', 'Executive readout & roadmap'] },
  { name: 'Follow-on', duration: 'Variable', activities: ['Remediation implementation', 'Type 2 observation period'] },
];
---

<div class="timeline">
  {phases.map((phase, i) => (
    <div class="timeline-phase">
      <div class="timeline-marker">
        <span class="timeline-number">{i + 1}</span>
      </div>
      <div class="timeline-connector" />
      <div class="timeline-content">
        <h3 class="timeline-name">{phase.name}</h3>
        <span class="timeline-duration">{phase.duration}</span>
        <ul class="timeline-activities">
          {phase.activities.map((a) => (
            <li>{a}</li>
          ))}
        </ul>
      </div>
    </div>
  ))}
</div>

<style>
  .timeline {
    display: flex;
    gap: 0;
    margin: 2rem 0;
    position: relative;
  }

  .timeline-phase {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
  }

  .timeline-marker {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: var(--color-accent-strong);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
    flex-shrink: 0;
  }

  .timeline-number {
    color: #ffffff;
    font-weight: 700;
    font-size: 0.9rem;
  }

  .timeline-connector {
    display: none;
  }

  /* Horizontal connector between markers */
  .timeline-phase:not(:last-child)::after {
    content: '';
    position: absolute;
    top: 1.25rem;
    left: calc(50% + 1.25rem);
    right: calc(-50% + 1.25rem);
    height: 2px;
    background: var(--color-border);
  }

  .timeline-content {
    text-align: center;
    margin-top: 1rem;
    padding: 0 0.5rem;
  }

  .timeline-name {
    color: var(--color-heading);
    font-size: 1rem;
    margin-bottom: 0.25rem;
  }

  .timeline-duration {
    display: inline-block;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 0.125rem 0.5rem;
    font-size: 0.8rem;
    color: var(--color-accent);
    font-weight: 600;
    margin-bottom: 0.75rem;
  }

  .timeline-activities {
    list-style: none;
    padding: 0;
    margin: 0;
    text-align: left;
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .timeline-activities li {
    padding: 0.2rem 0;
    margin: 0;
  }

  .timeline-activities li::before {
    content: '\2022';
    color: var(--color-accent);
    margin-right: 0.4rem;
  }

  @media (max-width: 768px) {
    .timeline {
      flex-direction: column;
      gap: 0;
    }

    .timeline-phase {
      flex-direction: row;
      align-items: flex-start;
      gap: 1rem;
      padding-bottom: 1.5rem;
    }

    .timeline-phase:not(:last-child)::after {
      content: '';
      position: absolute;
      top: 2.5rem;
      left: 1.25rem;
      right: auto;
      bottom: 0;
      width: 2px;
      height: auto;
    }

    .timeline-content {
      text-align: left;
      margin-top: 0;
      padding: 0;
    }
  }
</style>
