---
interface Props {
  domain: string;
  description: string;
  requirements: string[];
  evidence_examples: { artifact: string; owner: string; frequency: string }[];
  criteria: string[];
}

const { domain, description, requirements, evidence_examples, criteria } = Astro.props;
---

<article class="card control-card">
  <div class="control-header">
    <h3>{domain}</h3>
    <div class="criteria-tags">
      {criteria.map((c) => (
        <span class="tag">{c}</span>
      ))}
    </div>
  </div>
  <p class="control-description">{description}</p>

  <h4>Requirements</h4>
  <ul class="requirements-list">
    {requirements.map((req) => (
      <li>{req}</li>
    ))}
  </ul>

  <h4>Evidence Examples</h4>
  <div class="evidence-table-wrapper">
    <table class="evidence-table">
      <thead>
        <tr>
          <th>Artifact</th>
          <th>Owner</th>
          <th>Frequency</th>
        </tr>
      </thead>
      <tbody>
        {evidence_examples.map((e) => (
          <tr>
            <td>{e.artifact}</td>
            <td>{e.owner}</td>
            <td>{e.frequency}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</article>

<style>
  .control-card {
    margin-bottom: 1.5rem;
  }

  .control-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }

  .control-header h3 {
    margin-bottom: 0;
  }

  .control-description {
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .control-card h4 {
    font-size: 0.9rem;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: 1rem;
    margin-bottom: 0.5rem;
  }

  .requirements-list {
    padding-left: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .requirements-list li {
    font-size: 0.9rem;
    margin-bottom: 0.25rem;
  }

  .evidence-table-wrapper {
    overflow-x: auto;
  }

  .evidence-table {
    font-size: 0.85rem;
    margin-bottom: 0;
  }

  .evidence-table th {
    font-size: 0.8rem;
  }

  .criteria-tags {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
  }

  .tag {
    display: inline-block;
    background: var(--color-bg);
    border: 1px solid var(--color-accent);
    color: var(--color-accent);
    padding: 0.125rem 0.5rem;
    border-radius: var(--radius-sm);
    font-size: 0.75rem;
    font-weight: 600;
  }
</style>
